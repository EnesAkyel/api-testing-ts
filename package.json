{
  "name": "api-testing-ts",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:smoke": "jest --config jest.smoke.config.js",
    "test:contract": "jest --config jest.contract.config.js",
    "test:integration": "jest --config jest.integration.config.js",
    "test:regression": "jest --config jest.regression.config.js --verbose",
    "test:regression:local": "dotenv -e src/tests/regression-tests/.env.regression -- jest --config jest.regression.config.js --verbose",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "keywords": [],
  "author": "Enes Akyel",
  "license": "ISC",
  "description": "TypeScript API testing framework with typed HTTP client, AJV contract validation, Jest suite separation, and GitHub Actions CI/CD",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dotenv": "^8.2.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "ajv": "^8.20.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^17.0.0",
    "prettier": "^3.9.6",
    "ts-jest": "^29.4.12",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "form-data": "^4.0.6",
    "uuid": "^11.1.1",
    "babel-plugin-istanbul": "^8.0.2"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "fast-uri": "^4.1.1",
    "json-schema-traverse": "^1.0.0",
    "require-from-string": "^2.0.2"
  }
}
